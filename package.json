{
  "name": "Tikitak-FE",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:nopwa": "VITE_PWA_DISABLE=true vite build && vite preview",
    "test": "vitest",
    "type-check": "tsc --noEmit",
    "format:check": "prettier . --check",
    "gen:index": "tsx scripts/genIndex.ts",
    "gen:index:check": "tsx scripts/genIndex.ts --check",
    "tokens:sync": "tsx scripts/syncDesignTokens.ts",
    "tokens:build": "tsx scripts/buildDesignTokens.ts",
    "tokens:check": "yarn tokens:build && git diff --exit-code src/app/styles/tokens.css",
    "subset:fonts": "node scripts/subsetFonts.mjs",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "cap:sync": "yarn build && cap sync",
    "cap:sync:android": "yarn build && cap sync android",
    "cap:sync:ios": "yarn build && cap sync ios",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "cap:run:ios": "yarn build && cap run ios",
    "cap:run:android": "yarn build && cap run android",
    "cap:assets": "capacitor-assets generate --iconBackgroundColor \"#ffffff\" --splashBackgroundColor \"#ffffff\"",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install --with-deps",
    "e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/dialog": "^8.0.1",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@hookform/resolvers": "^5.2.2",
    "@ssgoi/react": "^6.4.0",
    "@tanstack/react-query": "^5.96.2",
    "axios": "^1.16.0",
    "capacitor-native-settings": "^8.1.0",
    "clsx": "^2.1.1",
    "overlay-kit": "^1.9.0",
    "pretendard": "^1.3.9",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "react-router": "^7.14.0",
    "supercluster": "^8.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.4",
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-onboarding": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/eslint-plugin-jsx-a11y": "^6",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/subset-font": "^2",
    "@types/supercluster": "^7.1.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "4.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "storybook": "^10.3.6",
    "style-dictionary": "^5.4.0",
    "subset-font": "^2.5.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.4"
  }
}
