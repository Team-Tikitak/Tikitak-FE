{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TikitakPrReviewOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "overall",
    "repo_rules_check",
    "findings",
    "test_gaps",
    "needs_confirmation",
    "warnings"
  ],
  "properties": {
    "overall": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verdict", "summary", "confidence"],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["looks_good", "needs_attention", "blocked", "insufficient_context"]
        },
        "summary": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "repo_rules_check": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "status", "detail"],
        "properties": {
          "source": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["satisfied", "partial", "missing", "unclear", "not_applicable"]
          },
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "category",
          "title",
          "body",
          "evidence",
          "recommendation",
          "confidence"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor", "info"]
          },
          "category": {
            "type": "string",
            "enum": [
              "repo_convention",
              "correctness",
              "accessibility",
              "type_safety",
              "test_gap",
              "security",
              "other"
            ]
          },
          "title": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "evidence": {
            "type": "object",
            "additionalProperties": false,
            "required": ["docs", "diff"],
            "properties": {
              "docs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "diff": {
                "type": "object",
                "additionalProperties": false,
                "required": ["file", "line_start", "line_end"],
                "properties": {
                  "file": {
                    "type": "string"
                  },
                  "line_start": {
                    "type": ["integer", "null"],
                    "minimum": 1
                  },
                  "line_end": {
                    "type": ["integer", "null"],
                    "minimum": 1
                  }
                }
              }
            }
          },
          "recommendation": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "test_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "needs_confirmation": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
